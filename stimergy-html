<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STIGMERGY — Coordination without a coordinator</title>
<meta name="description" content="STIGMERGY: autonomous agents build a shared, verifiable episodic memory through CockroachDB. No coordinator, no LLM in the decision path. / Agentes autónomos construyen una memoria episódica compartida y verificable a través de CockroachDB.">
<style>
  :root {
    --coral: #8FAB8C;
    --coral-light: #D7E6D3;
    --coral-deep: #567253;
    --lavender: #A88CAB;
    --lavender-light: #E7D8E8;
    --coral-glow: rgba(143, 171, 140, 0.36);
    --bg: #101510;
    --bg-soft: #182019;
    --bg-card: rgba(255, 255, 255, 0.055);
    --line: rgba(215, 230, 211, 0.17);
    --text: #F5F7F2;
    --muted: #BAC8B8;
    --mono: "SF Mono", "Fira Code", "JetBrains Mono", Consolas, monospace;
    --sans: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: radial-gradient(circle at 88% 4%, rgba(168, 140, 171, .16), transparent 26rem), var(--bg);
    color: var(--text);
    font-family: var(--sans);
    line-height: 1.65;
    overflow-x: hidden;
  }

  /* ---- Language switching ---- */
  .es { display: none; }
  body.lang-es .es { display: revert; }
  body.lang-es .en { display: none; }
  span.es, body.lang-es span.es { display: none; }
  body.lang-es span.es { display: inline; }

  ::selection { background: var(--coral); color: #112010; }

  /* ---- Language toggle ---- */
  .lang-toggle {
    position: fixed;
    top: 1.2rem;
    right: 1.4rem;
    z-index: 100;
    display: flex;
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 999px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    background: rgba(16, 21, 16, 0.72);
    box-shadow: 0 4px 24px rgba(0,0,0,0.35);
  }
  .lang-toggle button {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--muted);
    font: 600 0.8rem var(--sans);
    letter-spacing: 0.08em;
    padding: 0.55rem 1.1rem;
    cursor: pointer;
    transition: color .25s, background .25s;
  }
  .lang-toggle button.active {
    background: var(--coral);
    color: #112010;
  }
  .lang-toggle button:not(.active):hover { color: var(--coral-light); }

  /* ---- Jury navigation and evidence ---- */
  .site-nav {
    position: fixed;
    z-index: 90;
    top: 1.2rem;
    left: 1.4rem;
    display: flex;
    align-items: center;
    gap: .85rem;
    padding: .45rem .65rem .45rem .85rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(16, 21, 16, .72);
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0,0,0,.22);
  }
  .site-nav .nav-mark { color: var(--coral); font-size: 1rem; }
  .site-nav a { color: var(--muted); text-decoration: none; font: 650 .73rem var(--sans); letter-spacing: .08em; text-transform: uppercase; }
  .site-nav a:hover { color: var(--coral-light); }
  .nav-divider { width: 1px; height: 14px; background: var(--line); }

  .jury-strip { padding: 0 1.5rem; position: relative; z-index: 2; margin-top: -3.6rem; }
  .jury-strip-inner {
    max-width: 1060px; margin: 0 auto; padding: 1.05rem 1.25rem;
    border: 1px solid rgba(215,230,211,.25); border-radius: 18px;
    background: linear-gradient(100deg, rgba(143,171,140,.23), rgba(168,140,171,.2));
    display: grid; grid-template-columns: 1.2fr repeat(3, auto); gap: 1rem; align-items: center;
    box-shadow: 0 18px 50px rgba(0,0,0,.2);
  }
  .jury-strip-title { font-size: .9rem; color: var(--text); }
  .jury-strip-title strong { color: var(--coral-light); }
  .proof-chip { font: 650 .7rem var(--mono); color: var(--lavender-light); border: 1px solid rgba(231,216,232,.28); border-radius: 999px; padding: .35rem .6rem; white-space: nowrap; }

  .judge-grid { display: grid; grid-template-columns: .95fr 1.35fr; gap: 1.4rem; margin-top: 2.6rem; align-items: stretch; }
  .evidence-card, .memory-console { border: 1px solid var(--line); border-radius: 20px; background: var(--bg-card); overflow: hidden; }
  .evidence-card { padding: 1.55rem; }
  .evidence-card h3 { font-size: 1.08rem; margin-bottom: .5rem; }
  .evidence-card > p { color: var(--muted); font-size: .9rem; }
  .tool-evidence { list-style: none; margin-top: 1.25rem; display: grid; gap: .65rem; }
  .tool-evidence li { display: grid; grid-template-columns: 26px 1fr; gap: .7rem; padding: .65rem 0; border-top: 1px solid rgba(255,255,255,.07); }
  .tool-evidence b { display: block; font-size: .86rem; color: var(--text); }
  .tool-evidence span { display: block; font-size: .79rem; line-height: 1.45; color: var(--muted); }
  .tool-dot { width: 22px; height: 22px; border-radius: 7px; display: grid; place-items: center; background: rgba(143,171,140,.15); color: var(--coral); font: 700 .7rem var(--mono); }
  .memory-console { display: grid; grid-template-rows: auto 1fr auto; min-height: 365px; }
  .console-head { display: flex; justify-content: space-between; gap: 1rem; padding: 1rem 1.25rem; border-bottom: 1px solid var(--line); background: rgba(143,171,140,.07); }
  .console-title { font: 650 .75rem var(--mono); letter-spacing: .12em; color: var(--coral-light); text-transform: uppercase; }
  .console-state { color: var(--lavender-light); font: 650 .7rem var(--mono); }
  .console-body { padding: 1.35rem; display: grid; gap: 1rem; }
  .memory-object { border: 1px solid rgba(215,230,211,.18); border-radius: 14px; padding: 1rem; background: rgba(0,0,0,.14); }
  .memory-object .label { font: 650 .67rem var(--mono); letter-spacing: .1em; color: var(--muted); text-transform: uppercase; }
  .memory-object .memory-title { font-size: 1.02rem; color: var(--text); margin-top: .35rem; }
  .region-path { display: grid; grid-template-columns: 1fr auto 1fr; gap: .5rem; align-items: center; }
  .region { border: 1px solid var(--line); border-radius: 12px; padding: .75rem; color: var(--muted); font: .74rem var(--mono); }
  .region.active { border-color: rgba(168,140,171,.72); color: var(--lavender-light); background: rgba(168,140,171,.14); }
  .region.target { border-color: rgba(143,171,140,.72); color: var(--coral-light); background: rgba(143,171,140,.13); }
  .arrow { color: var(--coral); font-size: 1.15rem; }
  .event-log { font: .75rem/1.55 var(--mono); color: var(--muted); min-height: 3.2em; }
  .event-log b { color: var(--coral-light); font-weight: 600; }
  .console-foot { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding: 1rem 1.25rem; border-top: 1px solid var(--line); }
  .console-foot code { color: var(--lavender-light); font: .72rem var(--mono); }
  .sim-button { border: 0; border-radius: 999px; background: var(--coral); color: #112010; padding: .54rem .9rem; cursor: pointer; font: 750 .72rem var(--sans); }
  .sim-button:hover { background: var(--coral-light); }

  .architecture-map { margin-top: 2.8rem; padding: 1.4rem; border: 1px solid var(--line); border-radius: 22px; background: linear-gradient(135deg, rgba(143,171,140,.1), rgba(168,140,171,.09)); }
  .arch-flow { display: grid; grid-template-columns: 1fr 42px 1.25fr 42px 1fr; align-items: center; gap: .35rem; }
  .arch-node { min-height: 145px; border: 1px solid rgba(215,230,211,.2); border-radius: 16px; padding: 1.1rem; background: rgba(13,20,13,.54); transition: transform .25s, border-color .25s; }
  .arch-node:hover { transform: translateY(-3px); border-color: var(--coral); }
  .arch-node .node-tag { color: var(--coral); font: 700 .65rem var(--mono); letter-spacing: .1em; }
  .arch-node h3 { font-size: .98rem; margin: .4rem 0; }
  .arch-node p { color: var(--muted); font-size: .8rem; line-height: 1.45; }
  .arch-node.crdb { border-color: rgba(168,140,171,.45); background: rgba(168,140,171,.12); }
  .arch-node.crdb .node-tag { color: var(--lavender-light); }
  .arch-arrow { color: var(--coral); text-align: center; font: 700 1.45rem var(--mono); }
  .arch-caption { margin-top: 1rem; font-size: .83rem; color: var(--muted); text-align: center; }

  @media (max-width: 760px) {
    .site-nav { padding: .5rem .7rem; } .site-nav a, .nav-divider { display: none; }
    .jury-strip { margin-top: -1.5rem; } .jury-strip-inner { grid-template-columns: 1fr; gap: .55rem; }
    .proof-chip { width: fit-content; }
    .judge-grid { grid-template-columns: 1fr; }
    .arch-flow { grid-template-columns: 1fr; } .arch-arrow { transform: rotate(90deg); height: 25px; }
  }

  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    isolation: isolate;
  }
  #pheromones {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: .42;
    pointer-events: none;
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(ellipse at center, transparent 48%, rgba(16,21,16,.35) 100%);
    pointer-events: none;
    display: none;
  }
  .hero-inner {
    position: relative;
    z-index: 5;
    padding: 2rem 1.5rem;
    max-width: 900px;
    animation: heroRise .65s cubic-bezier(.2,.7,.2,1) both;
  }
  @keyframes heroRise {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: none; }
  }
  .hero .badge {
    display: inline-block;
    font: 600 0.72rem var(--mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--coral-light);
    border: 1px solid var(--line);
    background: rgba(143,171,140,0.12);
    border-radius: 999px;
    padding: 0.45rem 1.1rem;
    margin-bottom: 1.8rem;
  }
  .hero h1 {
    font-size: clamp(3.2rem, 11vw, 7.5rem);
    font-weight: 800;
    letter-spacing: 0.06em;
    line-height: 1;
    background: linear-gradient(115deg, #F6FBF4 15%, var(--coral) 52%, var(--lavender) 95%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 0 40px var(--coral-glow));
  }
  .hero .tagline {
    margin-top: 1.4rem;
    font-size: clamp(1.1rem, 2.6vw, 1.55rem);
    font-weight: 300;
    color: var(--text);
  }
  .hero .tagline strong { color: var(--coral); font-weight: 600; }
  .hero .sub {
    margin: 1.1rem auto 0;
    max-width: 620px;
    color: var(--muted);
    font-size: clamp(0.95rem, 1.8vw, 1.05rem);
  }
  .hero .cta-row {
    margin-top: 2.6rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    text-decoration: none;
    font: 600 0.95rem var(--sans);
    padding: 0.85rem 1.9rem;
    border-radius: 999px;
    transition: transform .25s, box-shadow .25s, background .25s;
  }
  .btn-primary {
    background: var(--coral);
    color: #112010;
    box-shadow: 0 0 0 rgba(143,171,140,0);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px var(--coral-glow);
  }
  .btn-ghost {
    color: var(--coral-light);
    border: 1px solid var(--line);
  }
  .btn-ghost:hover { background: rgba(168,140,171,0.15); transform: translateY(-2px); }

  .scroll-hint {
    z-index: 5;
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    animation: bob 2.4s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); opacity: .55; }
    50%      { transform: translate(-50%, 8px); opacity: 1; }
  }

  /* ---- Layout ---- */
  section { padding: 6.5rem 1.5rem; position: relative; }
  .wrap { max-width: 1060px; margin: 0 auto; }

  .kicker {
    font: 600 0.75rem var(--mono);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 0.9rem;
  }
  h2 {
    font-size: clamp(1.9rem, 4.5vw, 2.8rem);
    font-weight: 750;
    letter-spacing: -0.015em;
    line-height: 1.15;
    margin-bottom: 1.4rem;
  }
  .lede { color: var(--muted); font-size: 1.12rem; max-width: 720px; }
  .lede strong, p strong { color: var(--coral-light); font-weight: 600; }

  /* ---- Reveal on scroll ---- */
  .reveal {
    opacity: 0;
    transform: translateY(34px);
    transition: opacity .8s cubic-bezier(.2,.7,.2,1), transform .8s cubic-bezier(.2,.7,.2,1);
  }
  .reveal.in { opacity: 1; transform: none; }

  /* ---- Concept section ---- */
  .concept-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 3.5rem;
    align-items: center;
    margin-top: 2.5rem;
  }
  @media (max-width: 820px) { .concept-grid { grid-template-columns: 1fr; } }
  .concept-grid p + p { margin-top: 1rem; }
  .concept-grid p { color: var(--muted); }

  .term-card {
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 2.2rem;
    background: linear-gradient(145deg, rgba(143,171,140,0.18), rgba(168,140,171,0.08));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
  }
  .term-card .word {
    font-size: 1.7rem;
    font-weight: 750;
    color: var(--coral);
  }
  .term-card .ipa { font-family: var(--mono); color: var(--muted); font-size: .9rem; margin-left: .5rem; }
  .term-card .etym {
    margin-top: 0.8rem;
    font-size: 0.92rem;
    color: var(--muted);
  }
  .term-card .defn { margin-top: 1rem; color: var(--text); }
  .term-card .etym em { color: var(--coral-light); font-style: normal; font-family: var(--mono); font-size: .85rem; }

  /* ---- Flow / how it works ---- */
  .flow {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
    counter-reset: step;
  }
  @media (max-width: 980px) { .flow { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .flow { grid-template-columns: 1fr; } }
  .step {
    position: relative;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--bg-card);
    padding: 1.7rem 1.4rem 1.5rem;
    transition: transform .3s, border-color .3s, box-shadow .3s;
  }
  .step:hover {
    transform: translateY(-6px);
    border-color: rgba(168,140,171,0.55);
    box-shadow: 0 14px 40px rgba(0,0,0,0.35), 0 0 24px rgba(143,171,140,0.15);
  }
  .step::before {
    counter-increment: step;
    content: "0" counter(step);
    font: 700 0.8rem var(--mono);
    color: var(--coral);
    display: inline-block;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.25rem 0.55rem;
    margin-bottom: 0.9rem;
    background: rgba(143,171,140,0.12);
  }
  .step h3 { font-size: 1.05rem; margin-bottom: 0.5rem; }
  .step p { font-size: 0.9rem; color: var(--muted); }

  /* ---- Invariants ---- */
  .inv-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 1.1rem;
  }
  .inv {
    border: 1px solid var(--line);
    border-left: 3px solid var(--coral);
    border-radius: 14px;
    background: var(--bg-card);
    padding: 1.4rem 1.4rem 1.3rem;
    transition: transform .3s, background .3s;
  }
  .inv:hover { transform: translateY(-4px); background: rgba(168,140,171,0.12); }
  .inv .n {
    font: 700 0.75rem var(--mono);
    color: var(--coral);
    letter-spacing: .1em;
  }
  .inv h3 { font-size: 1rem; margin: 0.4rem 0 0.35rem; }
  .inv p { font-size: 0.88rem; color: var(--muted); }

  /* ---- Components table ---- */
  .table-scroll { overflow-x: auto; margin-top: 2.6rem; border: 1px solid var(--line); border-radius: 16px; }
  table { width: 100%; border-collapse: collapse; min-width: 640px; }
  th, td { text-align: left; padding: 1rem 1.3rem; }
  th {
    font: 600 0.72rem var(--mono);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--coral);
    border-bottom: 1px solid var(--line);
    background: rgba(143,171,140,0.1);
  }
  td { border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.93rem; color: var(--muted); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(168,140,171,0.09); }
  td code, p code, li code {
    font-family: var(--mono);
    font-size: 0.85em;
    color: var(--coral-light);
    background: rgba(143,171,140,0.13);
    padding: 0.15em 0.45em;
    border-radius: 6px;
  }

  /* ---- Why CRDB ---- */
  .pillar-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 880px) { .pillar-grid { grid-template-columns: 1fr; } }
  .pillar {
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 1.8rem 1.5rem;
    background: linear-gradient(180deg, rgba(168,140,171,0.16), transparent 60%);
    transition: transform .3s, border-color .3s;
  }
  .pillar:hover { transform: translateY(-5px); border-color: rgba(168,140,171,0.5); }
  .pillar .icon { font-size: 1.6rem; margin-bottom: 0.8rem; display: block; }
  .pillar h3 { font-size: 1.05rem; margin-bottom: 0.5rem; }
  .pillar p { font-size: 0.9rem; color: var(--muted); }

  /* ---- Failure philosophy ---- */
  .philosophy {
    background: var(--bg-soft);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .creed {
    margin-top: 2.6rem;
    display: grid;
    gap: 1rem;
    max-width: 780px;
  }
  .creed .rule {
    display: flex;
    gap: 1.1rem;
    align-items: baseline;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.2rem 1.5rem;
    background: var(--bg-card);
    font-size: 1.02rem;
  }
  .creed .rule .mark { color: var(--coral); font-family: var(--mono); font-weight: 700; flex: none; }
  .creed .final {
    margin-top: 1.6rem;
    font-size: clamp(1.15rem, 2.6vw, 1.45rem);
    font-weight: 650;
    color: var(--coral-light);
    line-height: 1.5;
  }

  /* ---- Honesty / limitations ---- */
  .honesty-list { margin-top: 2.2rem; display: grid; gap: 0.9rem; max-width: 820px; }
  .honesty-list li {
    list-style: none;
    border-left: 2px solid var(--coral-deep);
    padding: 0.35rem 0 0.35rem 1.2rem;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .honesty-list li strong { color: var(--text); }

  /* ---- Run it ---- */
  .code-block {
    margin-top: 2.4rem;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: #0B100B;
    overflow-x: auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }
  .code-block .bar {
    display: flex;
    gap: 0.45rem;
    padding: 0.85rem 1.2rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .code-block .bar i {
    width: 11px; height: 11px; border-radius: 50%;
    background: rgba(168,140,171,0.45);
  }
  .code-block .bar i:first-child { background: var(--coral); }
  .code-block pre {
    padding: 1.4rem 1.5rem;
    font: 0.86rem/1.7 var(--mono);
    color: #E5EEE2;
  }
  .code-block .c { color: #92A48F; }
  .code-block .k { color: var(--coral); }

  /* ---- Footer ---- */
  footer {
    border-top: 1px solid var(--line);
    padding: 3.5rem 1.5rem 4rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.9rem;
  }
  footer .logo {
    font: 800 1.1rem var(--sans);
    letter-spacing: 0.2em;
    color: var(--coral);
    margin-bottom: 0.8rem;
  }
  footer a { color: var(--coral-light); text-decoration: none; }
  footer a:hover { text-decoration: underline; }

  @media (prefers-reduced-motion: reduce) {
    .reveal, .hero-inner { transition: none; animation: none; opacity: 1; transform: none; }
    .scroll-hint { animation: none; }
    html { scroll-behavior: auto; }
  }
</style>
</head>
