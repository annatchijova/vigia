/* ---------- Replayable memory decision ---------- */
(function () {
  var button = document.getElementById('sim-button');
  var state = document.getElementById('sim-state');
  var log = document.getElementById('event-log');
  var hash = document.getElementById('audit-hash');
  var from = document.getElementById('from-region');
  var to = document.getElementById('to-region');
  if (!button || !state || !log) return;

  function isSpanish() { return document.body.classList.contains('lang-es'); }
  function setText(el, en, es) { el.innerHTML = isSpanish() ? es : en; }
  function wait(ms) { return new Promise(function (resolve) { setTimeout(resolve, ms); }); }
  function resetRegions() {
    from.className = 'region active';
    to.className = 'region target';
    from.textContent = 'cooking / current';
    to.textContent = 'databases / resonant';
  }
  async function replay() {
    if (button.disabled) return;
    button.disabled = true;
    button.style.opacity = '.65';
    resetRegions();
    state.textContent = 'RECALL';
    setText(log,
      '1. Vector recall finds a stronger semantic neighborhood in <b>databases</b>.',
      '1. La recuperación vectorial encuentra un vecindario semántico más fuerte en <b>databases</b>.');
    await wait(900);
    state.textContent = 'SIGNAL';
    setText(log,
      '2. A decaying recruitment signal is written to shared state — not sent to another agent.',
      '2. Se escribe una señal de reclutamiento que decae en el estado compartido — no se envía a otro agente.');
    await wait(1050);
    state.textContent = 'CONSENSUS';
    setText(log,
      '3. Independent observations cross the exact weighted-consensus threshold. Cooldown passes.',
      '3. Observaciones independientes superan el umbral exacto de consenso ponderado. El enfriamiento permite actuar.');
    await wait(1100);
    state.textContent = 'COMMIT + AUDIT';
    from.className = 'region';
    to.className = 'region target active';
    from.textContent = isSpanish() ? 'cocina / anterior' : 'cooking / previous';
    to.textContent = isSpanish() ? 'bases de datos / actual' : 'databases / current';
    setText(log,
      '4. Migration and audit event commit in one transaction. The node chain receives a new sealed link.',
      '4. La migración y el evento de auditoría confirman en una transacción. La cadena del nodo recibe un nuevo enlace sellado.');
    hash.textContent = 'audit_hash: 8f3a…c91e · merkle: verified';
    await wait(1300);
    state.textContent = 'VERIFIED';
    button.disabled = false;
    button.style.opacity = '1';
    setText(button, 'Replay again', 'Reproducir de nuevo');
  }
  button.addEventListener('click', replay);
})();

/* ---------- Scroll reveal ---------- */
(function () {
  var els = document.querySelectorAll('.reveal');
  if (!('IntersectionObserver' in window)) {
    els.forEach(function (el) { el.classList.add('in'); });
    return;
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  els.forEach(function (el) { io.observe(el); });
})();

/* ---------- Pheromone simulation (the wow) ----------
   Real stigmergy on a canvas: agents deposit pheromone into a grid,
   sense it ahead of them, steer toward stronger trails, and the
   field evaporates every frame. Trails emerge; nobody coordinates. */
(function () {
  var canvas = document.getElementById('pheromones');
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!canvas || reduce) return;
  var ctx = canvas.getContext('2d');

  var CELL = 4;                 // pheromone grid cell size in px
  var EVAPORATION = 0.965;      // per-frame decay (Invariant 7)
  var DEPOSIT = 1.0;
  var SENSE_DIST = 9;           // cells ahead
  var SENSE_ANGLE = Math.PI / 4;
  var TURN = 0.25;
  var SPEED = 1.35;

  var W, H, gw, gh, grid, agents;

  function resize() {
    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = canvas.clientWidth; H = canvas.clientHeight;
    canvas.width = W * dpr; canvas.height = H * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    gw = Math.ceil(W / CELL); gh = Math.ceil(H / CELL);
    grid = new Float32Array(gw * gh);
    var n = Math.min(240, Math.max(90, Math.floor(W * H / 9000)));
    agents = [];
    for (var i = 0; i < n; i++) {
      agents.push({
        x: Math.random() * W,
        y: Math.random() * H,
        a: Math.random() * Math.PI * 2
      });
    }
  }

  function sense(ag, offset) {
    var a = ag.a + offset;
    var cx = Math.floor((ag.x + Math.cos(a) * SENSE_DIST * CELL) / CELL);
    var cy = Math.floor((ag.y + Math.sin(a) * SENSE_DIST * CELL) / CELL);
    if (cx < 0) cx += gw; if (cx >= gw) cx -= gw;
    if (cy < 0) cy += gh; if (cy >= gh) cy -= gh;
    return grid[cy * gw + cx];
  }

  function step() {
    // evaporate (pheromones are never permanently binding)
    for (var i = 0; i < grid.length; i++) grid[i] *= EVAPORATION;

    for (var k = 0; k < agents.length; k++) {
      var ag = agents[k];
      var L = sense(ag, -SENSE_ANGLE), C = sense(ag, 0), R = sense(ag, SENSE_ANGLE);
      if (C >= L && C >= R) { /* keep heading */ }
      else if (L > R) ag.a -= TURN;
      else if (R > L) ag.a += TURN;
      else ag.a += (Math.random() - 0.5) * TURN;
      ag.a += (Math.random() - 0.5) * 0.18; // exploration noise

      ag.x += Math.cos(ag.a) * SPEED;
      ag.y += Math.sin(ag.a) * SPEED;
      if (ag.x < 0) ag.x += W; if (ag.x >= W) ag.x -= W;
      if (ag.y < 0) ag.y += H; if (ag.y >= H) ag.y -= H;

      var gx = Math.floor(ag.x / CELL), gy = Math.floor(ag.y / CELL);
      var idx = gy * gw + gx;
      if (idx >= 0 && idx < grid.length) {
        grid[idx] = Math.min(grid[idx] + DEPOSIT, 3);
      }
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // pheromone field in coral
    for (var y = 0; y < gh; y++) {
      for (var x = 0; x < gw; x++) {
        var v = grid[y * gw + x];
        if (v > 0.06) {
          var t = Math.min(v / 2.2, 1);
          ctx.fillStyle = 'rgba(143, 171, 140, ' + (t * 0.36).toFixed(3) + ')';
          ctx.fillRect(x * CELL, y * CELL, CELL, CELL);
        }
      }
    }

    // agents as bright motes
    ctx.fillStyle = '#E7D8E8';
    for (var k = 0; k < agents.length; k++) {
      var ag = agents[k];
      ctx.beginPath();
      ctx.arc(ag.x, ag.y, 1.4, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  var running = true;
  function loop() {
    if (running) { step(); draw(); }
    requestAnimationFrame(loop);
  }

  // pause when the hero is off-screen
  if ('IntersectionObserver' in window) {
    new IntersectionObserver(function (entries) {
      running = entries[0].isIntersecting;
    }, { threshold: 0 }).observe(canvas);
  }

  var resizeT;
  window.addEventListener('resize', function () {
    clearTimeout(resizeT);
    resizeT = setTimeout(resize, 150);
  });

  resize();
  loop();
})();
</script>
