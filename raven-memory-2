/* ============================================================
   Memory field engine — dependency-free Voronoi via low-res
   nearest-seed rasterisation. Mirrors the real engine's rules:
   ternary states, hop decay e^(−0.15·h), inhibition by
   REINFORCED neighbors, sleep consolidation of NEUTRAL clusters.
   ============================================================ */
const COLORS = {
  R:{fill:[233,185,77], glow:"rgba(233,185,77,.55)"},
  N:{fill:[52,63,92]},
  F:{fill:[22,28,46]},
  SEM:{fill:[139,124,246]},
};
const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

class Field {
  constructor(canvas, opts={}){
    this.cv = canvas;
    this.cx = canvas.getContext("2d");
    this.interactive = !!opts.interactive;
    this.res = opts.res || 5;           // raster cell size in px
    this.mems = [];                      // {id,x,y,vx,vy,state,layer,topic,claim,label,recalls,born}
    this.links = [];                     // {a,b,type:'INH'|'RES'}
    this.pulses = [];                    // visual effects
    this.flashes = new Map();            // id -> {color,until}
    this.selected = null;
    this.nextId = 1;
    this.adj = new Map();
    this._raf = null;
    this._visible = true;
    this.onChange = opts.onChange || (()=>{});
    this._resize();
    window.addEventListener("resize", ()=>this._resize());
    if(this.interactive){
      canvas.addEventListener("click", e=>this._click(e));
    }
    const io = new IntersectionObserver(es=>{ this._visible = es[0].isIntersecting; });
    io.observe(canvas);
    this._loop = this._loop.bind(this);
    requestAnimationFrame(this._loop);
  }
  _resize(){
    const r = this.cv.getBoundingClientRect();
    const dpr = Math.min(window.devicePixelRatio||1, 2);
    this.w = Math.max(300, r.width); this.h = Math.max(300, r.height);
    this.cv.width = this.w*dpr; this.cv.height = this.h*dpr;
    this.cx.setTransform(dpr,0,0,dpr,0,0);
    this.cols = Math.ceil(this.w/this.res); this.rows = Math.ceil(this.h/this.res);
    this.nearest = new Int16Array(this.cols*this.rows);
    this.off = document.createElement("canvas");
    this.off.width = this.cols; this.off.height = this.rows;
    this.ocx = this.off.getContext("2d");
    this.img = this.ocx.createImageData(this.cols, this.rows);
  }
  addMem(o){
    const m = Object.assign({
      id:this.nextId++, x:30+Math.random()*(this.w-60), y:30+Math.random()*(this.h-60),
      vx:(Math.random()-.5)*.12, vy:(Math.random()-.5)*.12,
      state:"N", layer:"episodic", topic:null, claim:null,
      label:t("mem.fact"), recalls:0, born:performance.now(), scale:0
    }, o);
    this.mems.push(m);
    // auto inhibitory wiring on contradicting claims (mirrors _auto_link_contradictions)
    if(m.topic && m.claim){
      for(const o2 of this.mems){
        if(o2.id!==m.id && o2.topic===m.topic && o2.claim && o2.claim!==m.claim){
          if(!this.links.some(l=>(l.a===m.id&&l.b===o2.id)||(l.a===o2.id&&l.b===m.id))){
            this.links.push({a:m.id,b:o2.id,type:"INH"});
          }
        }
      }
    }
    this.onChange(); return m;
  }
  byId(id){ return this.mems.find(m=>m.id===id); }
  setState(id, s){ const m=this.byId(id); if(m){ m.state=s; this.flash(id, s==="R"?"gold":"cyan"); this.onChange(); } }
  flash(id, color){ this.flashes.set(id,{color,until:performance.now()+900}); }
  stats(){
    const live = this.mems.filter(m=>m.state!=="F");
    const r = live.filter(m=>m.state==="R").length;
    const n = live.filter(m=>m.state==="N").length;
    const w = r*1.5+n;
    return {
      mss: w>0 ? (r*1.5)/w : 0,
      retention: this.mems.length? live.length/this.mems.length : 1,
      cells: this.mems.length,
      inhib: this.links.filter(l=>l.type==="INH").length,
    };
  }
  /* -------- recall: nearest cell + BFS hops + ternary boosts + inhibition -------- */
  recall(qx, qy){
    if(!this.mems.length) return {results:[],silenced:[]};
    let best=-1,bd=1e12;
    this.mems.forEach((m,i)=>{ const d=(m.x-qx)**2+(m.y-qy)**2; if(d<bd){bd=d;best=i;} });
    const start = this.mems[best].id;
    // BFS over Voronoi adjacency (this.adj computed during raster pass)
    const hops = new Map([[start,0]]);
    let frontier=[start];
    for(let h=1;h<=2;h++){
      const nf=[];
      for(const id of frontier) for(const nb of (this.adj.get(id)||[]))
        if(!hops.has(nb)){ hops.set(nb,h); nf.push(nb); }
      frontier=nf;
    }
    const maxD = Math.hypot(this.w,this.h);
    const boost = {R:1.5,N:1.0,F:0.1};
    const cands=[];
    for(const [id,h] of hops){
      const m=this.byId(id); if(!m) continue;
      const sim = Math.max(0, 1 - Math.hypot(m.x-qx,m.y-qy)/(maxD*0.55));
      const score = sim * boost[m.state] * Math.exp(-0.15*h);
      cands.push({m, h, score});
    }
    // inhibition: a candidate linked INH to an activated REINFORCED cell is silenced
    const actIds = new Set(cands.map(c=>c.m.id));
    const silenced=[];
    const results = cands.filter(c=>{
      if(c.m.state==="R") return true;
      const inhibitor = this.links.some(l=> l.type==="INH" &&
        ((l.a===c.m.id && actIds.has(l.b) && this.byId(l.b)?.state==="R") ||
         (l.b===c.m.id && actIds.has(l.a) && this.byId(l.a)?.state==="R")));
      if(inhibitor){ silenced.push(c); return false; }
      return true;
    }).filter(c=>c.m.state!=="F");
    results.sort((a,b)=>b.score-a.score);
    results.forEach(c=>{ c.m.recalls++; this.flash(c.m.id,"cyan"); });
    silenced.forEach(c=>this.flash(c.m.id,"ember"));
    this.pulses.push({x:qx,y:qy,r:6,max:Math.max(this.w,this.h)*0.5,born:performance.now()});
    this.onChange();
    return {results:results.slice(0,6), silenced};
  }
  /* -------- sleep: cluster NEUTRAL episodic cells, animate merge -------- */
  sleep(done){
    const cand = this.mems.filter(m=>m.state==="N" && m.layer==="episodic");
    const groups=[]; const used=new Set();
    for(const m of cand){
      if(used.has(m.id)) continue;
      const g=[m]; used.add(m.id);
      for(const o of cand){
        if(used.has(o.id)) continue;
        if(Math.hypot(m.x-o.x,m.y-o.y) < Math.min(this.w,this.h)*0.24){ g.push(o); used.add(o.id); }
      }
      if(g.length>=2) groups.push(g);
    }
    if(!groups.length){ if(done) done(0); return 0; }
    this.night = {start:performance.now(), dur:2200};
    for(const g of groups){
      const cx0 = g.reduce((s,m)=>s+m.x,0)/g.length, cy0 = g.reduce((s,m)=>s+m.y,0)/g.length;
      g.forEach(m=>{ m.mergeTo={x:cx0,y:cy0,start:performance.now()+300,dur:1200}; });
      setTimeout(()=>{
        const ids = new Set(g.map(m=>m.id));
        this.links = this.links.filter(l=>!ids.has(l.a)&&!ids.has(l.b));   // cascade
        this.mems = this.mems.filter(m=>!ids.has(m.id));
        this.addMem({x:cx0,y:cy0,state:"N",layer:"semantic",label:t("mem.cons"),
          topic:g[0].topic, claim:g[0].claim});
        this.onChange();
      }, 1650);
    }
    if(done) setTimeout(()=>done(groups.length), 2100);
    return groups.length;
  }
  reset(){ this.mems=[]; this.links=[]; this.pulses=[]; this.flashes.clear(); this.selected=null; this.nextId=1; this.onChange(); }
  _click(e){
    const r=this.cv.getBoundingClientRect();
    const x=e.clientX-r.left, y=e.clientY-r.top;
    // select if close to an existing seed, otherwise plant a new memory
    let hit=null;
    for(const m of this.mems) if(Math.hypot(m.x-x,m.y-y)<22) hit=m;
    if(hit){ this.selected = (this.selected===hit.id? null : hit.id); }
    else this.addMem({x,y,label:t("mem.fact")});
  }
  /* -------- render -------- */
  _loop(now){
    requestAnimationFrame(this._loop);
    if(!this._visible) return;
    const {cx,w,h}=this;
    // drift
    if(!reduceMotion){
      for(const m of this.mems){
        if(m.mergeTo){
          const k=Math.min(1,Math.max(0,(now-m.mergeTo.start)/m.mergeTo.dur));
          const e=k*k*(3-2*k);
          m.x += (m.mergeTo.x-m.x)*e*0.18; m.y += (m.mergeTo.y-m.y)*e*0.18;
        } else {
          m.x+=m.vx; m.y+=m.vy;
          if(m.x<24||m.x>w-24) m.vx*=-1;
          if(m.y<24||m.y>h-24) m.vy*=-1;
        }
        if(m.scale<1) m.scale=Math.min(1,m.scale+0.06);
      }
    } else { for(const m of this.mems) m.scale=1; }
    this._raster(now);
    cx.clearRect(0,0,w,h);
    cx.imageSmoothingEnabled = true;
    cx.drawImage(this.off,0,0,w,h);
    this._drawLinks(now);
    this._drawSeeds(now);
    this._drawPulses(now);
    this._drawNight(now);
  }
  _raster(now){
    const {cols,rows,res,mems}=this;
    const n=mems.length, data=this.img.data, nearest=this.nearest;
    this.adj = new Map(mems.map(m=>[m.id,new Set()]));
    if(!n){ data.fill(0); this.ocx.putImageData(this.img,0,0); return; }
    const xs=new Float32Array(n), ys=new Float32Array(n);
    for(let i=0;i<n;i++){ xs[i]=mems[i].x; ys[i]=mems[i].y; }
    for(let gy=0; gy<rows; gy++){
      const py=(gy+0.5)*res;
      for(let gx=0; gx<cols; gx++){
        const px=(gx+0.5)*res;
        let bi=0, bd=1e12;
        for(let i=0;i<n;i++){
          const dx=xs[i]-px, dy=ys[i]-py, d=dx*dx+dy*dy;
          if(d<bd){bd=d;bi=i;}
        }
        const idx=gy*cols+gx;
        nearest[idx]=bi;
        // adjacency from raster neighbors
        if(gx>0){ const l=nearest[idx-1]; if(l!==bi){ this.adj.get(mems[bi].id).add(mems[l].id); this.adj.get(mems[l].id).add(mems[bi].id); } }
        if(gy>0){ const u=nearest[idx-cols]; if(u!==bi){ this.adj.get(mems[bi].id).add(mems[u].id); this.adj.get(mems[u].id).add(mems[bi].id); } }
        const m=mems[bi];
        const base = m.layer==="semantic" ? COLORS.SEM.fill : COLORS[m.state].fill;
        // breathing per-cell
        const br = m.state==="R" ? 0.78+0.22*Math.sin(now/640 + m.id*1.7)
                 : m.state==="F" ? 0.35
                 : 0.55+0.12*Math.sin(now/900 + m.id*2.3);
        const dist=Math.sqrt(bd), fall = Math.max(0.34, 1 - dist/(Math.min(this.w,this.h)*0.42));
        const a = m.state==="F"? 0.5 : br*fall*m.scale;
        const o=idx*4;
        data[o]  = base[0]*a + 10*(1-a);
        data[o+1]= base[1]*a + 13*(1-a);
        data[o+2]= base[2]*a + 22*(1-a);
        data[o+3]= 255;
        // edge darkening
        if(gx>0 && nearest[idx-1]!==bi){ data[o]=10;data[o+1]=13;data[o+2]=22; }
      }
    }
    this.ocx.putImageData(this.img,0,0);
  }
  _drawLinks(now){
    const cx=this.cx;
    for(const l of this.links){
      const a=this.byId(l.a), b=this.byId(l.b); if(!a||!b) continue;
      cx.beginPath();
      const mx=(a.x+b.x)/2, my=(a.y+b.y)/2 - 26;
      cx.moveTo(a.x,a.y); cx.quadraticCurveTo(mx,my,b.x,b.y);
      if(l.type==="INH"){
        const p=0.55+0.45*Math.sin(now/300);
        cx.strokeStyle=`rgba(226,96,78,${0.5*p+0.2})`; cx.setLineDash([5,5]);
      } else { cx.strokeStyle="rgba(94,230,208,.5)"; cx.setLineDash([]); }
      cx.lineWidth=1.5; cx.stroke(); cx.setLineDash([]);
    }
  }
  _drawSeeds(now){
    const cx=this.cx;
    for(const m of this.mems){
      const fl=this.flashes.get(m.id);
      let ring=null;
      if(fl){ if(now>fl.until) this.flashes.delete(m.id);
        else ring = fl.color==="gold"?"rgba(233,185,77,.9)": fl.color==="ember"?"rgba(226,96,78,.9)":"rgba(94,230,208,.9)"; }
      const R = (m.layer==="semantic"?7.5:5.5)*m.scale;
      if(m.state==="R"){
        cx.shadowColor=COLORS.R.glow; cx.shadowBlur=18;
        cx.fillStyle="#F2CB6E";
      } else if(m.layer==="semantic"){
        cx.shadowColor="rgba(139,124,246,.5)"; cx.shadowBlur=12; cx.fillStyle="#A89BFA";
      } else {
        cx.shadowBlur=0;
        cx.fillStyle = m.state==="F" ? "rgba(120,130,160,.35)" : "#7E8AA8";
      }
      cx.beginPath(); cx.arc(m.x,m.y,R,0,7); cx.fill(); cx.shadowBlur=0;
      if(m.layer==="semantic"){ cx.strokeStyle="rgba(233,185,77,.8)"; cx.lineWidth=1.4;
        cx.beginPath(); cx.arc(m.x,m.y,R+4.5,0,7); cx.stroke(); }
      if(ring){ cx.strokeStyle=ring; cx.lineWidth=2;
        const k=1-(fl.until-now)/900;
        cx.beginPath(); cx.arc(m.x,m.y,R+5+k*16,0,7); cx.stroke(); }
      if(this.interactive && this.selected===m.id){
        cx.strokeStyle="rgba(233,236,245,.85)"; cx.lineWidth=1.6; cx.setLineDash([3,4]);
        cx.beginPath(); cx.arc(m.x,m.y,R+8,0,7); cx.stroke(); cx.setLineDash([]);
      }
    }
  }
  _drawPulses(now){
    const cx=this.cx;
    this.pulses = this.pulses.filter(p=> now-p.born < 1100);
    for(const p of this.pulses){
      const k=(now-p.born)/1100, r=p.r+(p.max-p.r)*k;
      cx.strokeStyle=`rgba(94,230,208,${0.55*(1-k)})`; cx.lineWidth=1.6;
      cx.beginPath(); cx.arc(p.x,p.y,r,0,7); cx.stroke();
    }
  }
  _drawNight(now){
    if(!this.night) return;
    const k=(now-this.night.start)/this.night.dur;
    if(k>=1){ this.night=null; return; }
    const a = k<0.4? k/0.4 : k>0.75? (1-k)/0.25 : 1;
    const cx=this.cx;
    cx.fillStyle=`rgba(6,8,16,${0.55*a})`; cx.fillRect(0,0,this.w,this.h);
    cx.fillStyle=`rgba(233,236,245,${0.85*a})`;
    cx.font="22px serif"; cx.fillText("☾", this.w-46, 40);
    for(let i=0;i<14;i++){
      const sx=(i*97)%this.w, sy=(i*53)%Math.max(1,(this.h*0.5));
      cx.fillStyle=`rgba(233,236,245,${(0.25+0.5*Math.abs(Math.sin(now/500+i)))*a})`;
      cx.fillRect(sx,sy,1.6,1.6);
    }
  }
}

