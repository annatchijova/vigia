/* ============================================================
   AUDIT CHAIN demo — real SHA-256 via SubtleCrypto, FNV fallback.
   Blocks generated from playground operations.
   ============================================================ */
const enc = new TextEncoder();
async function sha(s){
  try{
    const d = await crypto.subtle.digest("SHA-256", enc.encode(s));
    return [...new Uint8Array(d)].map(b=>b.toString(16).padStart(2,"0")).join("");
  }catch(_){
    let h=0xcbf29ce484222325n; const P=0x100000001b3n;
    for(const c of enc.encode(s)){ h^=BigInt(c); h=(h*P)&0xFFFFFFFFFFFFFFFFn; }
    return h.toString(16).padStart(16,"0").repeat(4);
  }
}
const GENESIS="0".repeat(64);
let auditLog=[];   // {op, payload, prevHash, hash, tampered}
// Mirror the production scheme: the hashed payload includes the content_hash
// of each retrieved memory. Editing a memory's text therefore breaks hash
// recomputation — exactly as in memory_engine.compute_audit_hash.
async function memContentHash(label){ return (await sha(label)).slice(0,16); }
async function chainAppend(op){
  const prev = auditLog.length? auditLog[auditLog.length-1].hash : GENESIS;
  // snapshot the live field's top cells as the "retrieved" set
  const snap = pg.mems.slice(0,3).map(m=>m.label);
  const results = [];
  for(const lbl of snap) results.push({c:lbl, ch: await memContentHash(lbl)});
  const payloadObj = {ts:Date.now(), op, n:auditLog.length+1, results};
  const payload = JSON.stringify(payloadObj);
  const hash = await sha(payload+prev);
  auditLog.push({op, payload, prevHash:prev, hash, tampered:false});
  if(auditLog.length>8) auditLog=auditLog.slice(-8);
  renderChain();
}
function renderChain(marks={}){
  const c=document.getElementById("chain"); c.innerHTML="";
  auditLog.forEach((b,i)=>{
    const d=document.createElement("div");
    d.className="block"+(b.tampered?" tampered":"")+(marks[i]==="ok"?" ok":marks[i]==="bad"?" bad":"");
    d.setAttribute("role","button"); d.tabIndex=0;
    d.title = LANG==="zh" ? "点击篡改此区块（修改记忆内容）" : "Click to tamper (edits memory content)";
    d.innerHTML=`<span class="op">${b.op}${b.tampered?" ⚠":""}</span>
      <div class="h">${b.hash.slice(0,18)}…</div>
      <div class="ph">prev ${b.prevHash.slice(0,14)}…</div>`;
    // Tamper by editing the retrieved content INSIDE the payload — the content
    // hash no longer matches, so verification must fail. This is the real
    // attack the production chain defends against.
    const tamper=()=>{ b.payload=b.payload.replace(/"c":"[^"]*"/, '"c":"FALSIFIED"'); b.tampered=true; renderChain(); setVerdict(null); };
    d.addEventListener("click",tamper);
    d.addEventListener("keydown",e=>{ if(e.key==="Enter"||e.key===" "){e.preventDefault();tamper();} });
    c.appendChild(d);
  });
}
let _lastVerdict = null;   // remember verdict so a language switch re-translates it
function setVerdict(state){
  _lastVerdict = state;
  const v=document.getElementById("chainVerdict");
  v.className= state===true?"ok": state===false?"bad":"";
  v.textContent = state===true? t("au.ok") : state===false? t("au.bad") : t("au.idle");
}
document.getElementById("bVerify").onclick=async ()=>{
  const marks={}; let ok=true;
  for(let i=0;i<auditLog.length;i++){
    const b=auditLog[i];
    const linkOk = b.prevHash === (i===0? b.prevHash : auditLog[i-1].hash);
    const recomputed = await sha(b.payload+b.prevHash);
    const good = linkOk && recomputed===b.hash;
    marks[i]= good? "ok":"bad"; if(!good) ok=false;
  }
  renderChain(marks); setVerdict(ok);
};
document.getElementById("bHeal").onclick=async ()=>{
  const ops=auditLog.map(b=>b.op.replace("falsified","recall"));
  auditLog=[];
  for(const op of (ops.length?ops:["recall","recall","consolidation","recall"])) await chainAppend(op);
  setVerdict(null);
};
(async function seedChain(){
  for(const op of ["recall","recall","consolidation","recall"]) await chainAppend(op);
})();

